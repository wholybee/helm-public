{
  "_SHELL_NOTE": "FALLBACK MIRROR — do not hand-edit to add layers. As of SHELL-2 the live style is assembled by HelmShell.buildStyle() from the per-domain fragments in web/style/ (helm-base + helm-chart-*/helm-route-*/helm-wx-*/helm-place-*/helm-ais-* per web/style/manifest.json). This monolithic file is only the zero-risk fallback used when that manifest can't be fetched, and is kept byte-equivalent to the merged result. To add map layers for your epic, create a web/style/helm-<epic>-*.json fragment and list it in the manifest (see web/SHELL.md) — never edit this file.",
  "version": 8,
  "name": "Helm — tracer bullet",
  "glyphs": "fonts/{fontstack}/{range}.pbf",
  "sources": {
    "sat": {
      "type": "raster",
      "tileSize": 256,
      "tiles": [
        "data/sat/{z}/{x}/{y}.jpg"
      ],
      "minzoom": 8,
      "maxzoom": 13,
      "bounds": [176.9, -18.2, 177.9, -17.2],
      "attribution": "Sentinel-2 cloudless by EOX (CC-BY-4.0) — baked offline"
    },
    "navionics": {
      "type": "raster",
      "tileSize": 256,
      "url": "pmtiles://http://localhost:8091/navionics.pmtiles",
      "minzoom": 7,
      "maxzoom": 17,
      "bounds": [175.0, -22.5, 180.5, -11.0],
      "attribution": "Navionics — owned chart pack (Fiji TCL2407)"
    },
    "googlesat": {
      "type": "raster", "tileSize": 256,
      "url": "pmtiles://http://localhost:8091/googlesat.pmtiles",
      "minzoom": 7, "maxzoom": 17, "bounds": [175.0, -22.5, 180.5, -11.0],
      "attribution": "Google satellite — owned (Fiji TCL2407)"
    },
    "bingsat": {
      "type": "raster", "tileSize": 256,
      "url": "pmtiles://http://localhost:8091/bingsat.pmtiles",
      "minzoom": 7, "maxzoom": 17, "bounds": [175.0, -22.5, 180.5, -11.0],
      "attribution": "Bing satellite — owned (Fiji TCL2407)"
    },
    "arcgis": {
      "type": "raster", "tileSize": 256,
      "url": "pmtiles://http://localhost:8091/arcgis.pmtiles",
      "minzoom": 7, "maxzoom": 17, "bounds": [175.0, -22.5, 180.5, -11.0],
      "attribution": "ArcGIS satellite — owned (Fiji TCL2407)"
    },
    "charts": {
      "type": "raster",
      "tileSize": 256,
      "tiles": [
        "https://tileservice.charts.noaa.gov/tiles/50000_1/{z}/{x}/{y}.png"
      ],
      "attribution": "NOAA ENC (public domain)"
    },
    "enc": {
      "type": "raster",
      "tileSize": 256,
      "minzoom": 10,
      "maxzoom": 17,
