      ],
      "attribution": "S-52 via OpenCPN (Helm Engine)",
      "_note": "default origin only — index.html rewrites this to the resolved boat-server origin (server-endpoint.js) at load, so it is address-agnostic (localhost / helm.local / LAN IP)"
    },
    "depare": {
      "type": "geojson",
      "data": "data/depare.geojson"
    },
    "depcnt": {
      "type": "geojson",
      "data": "data/depcnt.geojson"
    },
    "soundg": {
      "type": "geojson",
      "data": "data/soundg.geojson"
    },
    "route": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "wind": {
      "type": "geojson",
      "data": "data/wind_points.geojson"
    },
    "places": {
      "type": "geojson",
      "data": "data/places.geojson",
