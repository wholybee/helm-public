# Generated by the pipeline — local/private outputs are not committed by default.
# The small Key West public demo fixtures listed in DEMO-DATA.md are explicitly
# unignored below so the web client stays runnable without private chart data.
*.mbtiles
depare.geojson
depcnt.geojson
soundg.geojson
wind.json
wind_points.geojson
places.geojson
field-*.json
waves.json
swell.json
current.json
*-points.geojson
*-t*.json
forecast.json

# Keep the committed synthetic public demo fixtures.
!.gitignore
!depare.geojson
!depcnt.geojson
!soundg.geojson
!wind_points.geojson
!places.geojson
