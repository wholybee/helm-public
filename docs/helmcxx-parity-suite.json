{
  "schema": "helm.helmcxx_parity_suite.v1",
  "owner": "HELMC++-2",
  "updated": "2026-07-05",
  "policy": {
    "runtime_inventory": "docs/runtime-inventory.json",
    "acceptance_contract": "docs/HELMCXX-ACCEPTANCE.md",
    "default_mode": "static contract coverage validation",
    "contract_run_mode": "scripts/helmcxx-parity-suite.py --run-contracts",
    "python_rule": "Python services listed here are oracle/reference/dev/offline/optional only and must not be required boat runtime."
  },
  "required_surfaces": [
    "health",
    "catalog",
    "layers",
    "prefetch",
    "bundle",
    "tile_or_range_response",
    "metadata_allowlist",
    "stale_offline_out_of_coverage",
    "expected_404_204_invalid",
    "environmental_manifest_or_chunk",
    "headers_cache_semantics"
  ],
  "services": [
    {
      "id": "helm-server",
      "runtime_inventory_entry": "helm-server",
      "role": "one-origin nav, chart, health, catalog, static UI, nav websocket",
      "language": "C++17",
      "status": "required-runtime",
      "oracle": "OpenCPN model/chart behavior plus previous helm-server contract smoke outputs",
      "coverage": {
        "health": ["engine/test-engine.sh", "engine/test-no-enc-boot.sh"],
        "catalog": ["engine/test-engine.sh", "engine/test-no-enc-boot.sh"],
        "tile_or_range_response": ["engine/test-engine.sh", "engine/test-no-enc-boot.sh"],
        "stale_offline_out_of_coverage": ["engine/test-no-enc-boot.sh"],
        "expected_404_204_invalid": ["engine/test-engine.sh"],
        "headers_cache_semantics": ["engine/test-engine.sh", "engine/test-no-enc-boot.sh"]
      },
      "commands": [
        {
          "id": "helm-server-no-enc",
          "command": ["bash", "engine/test-no-enc-boot.sh"],
          "requires_any_env": ["HELM_SERVER_BIN", "HELM_OCPN_DIR"],
          "proves": ["health", "catalog", "tile_or_range_response", "stale_offline_out_of_coverage", "headers_cache_semantics"]
        },
        {
