        "headers_cache_semantics": ["pipeline/test_helm_packd_contract.py"]
      },
      "commands": [
        {
          "id": "helm-packd-contract",
          "command": ["python3", "pipeline/test_helm_packd_contract.py"],
          "requires_env": ["HELM_PACKD_BIN"],
          "proves": ["health", "catalog", "layers", "prefetch", "bundle", "tile_or_range_response", "metadata_allowlist", "stale_offline_out_of_coverage", "expected_404_204_invalid", "environmental_manifest_or_chunk", "headers_cache_semantics"]
        },
        {
          "id": "pack-oracle-layer-inventory",
          "command": ["python3", "pipeline/test_layer_inventory.py"],
          "oracle_only": true,
          "proves": ["layers", "metadata_allowlist"]
        },
        {
          "id": "pack-oracle-prefetch",
          "command": ["python3", "pipeline/test_prefetch_manifest.py"],
          "oracle_only": true,
          "proves": ["prefetch", "stale_offline_out_of_coverage", "expected_404_204_invalid"]
        },
        {
          "id": "pack-oracle-region-bundle",
          "command": ["python3", "pipeline/test_region_bundle.py"],
          "oracle_only": true,
          "proves": ["bundle", "metadata_allowlist", "stale_offline_out_of_coverage"]
        }
      ]
    },
