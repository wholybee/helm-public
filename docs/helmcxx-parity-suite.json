        "stale_offline_out_of_coverage": ["engine/test-basemap-cache.sh"],
        "expected_404_204_invalid": ["engine/test-basemap-cache.sh"],
        "headers_cache_semantics": ["engine/test-basemap-cache.sh"]
      },
      "commands": [
        {
