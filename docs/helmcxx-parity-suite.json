        "metadata_allowlist": ["pipeline/test_helm_envd_contract.py"],
        "stale_offline_out_of_coverage": ["pipeline/test_helm_envd_contract.py"],
        "expected_404_204_invalid": ["pipeline/test_helm_envd_contract.py"],
        "environmental_manifest_or_chunk": ["pipeline/test_helm_envd_contract.py"],
        "headers_cache_semantics": ["pipeline/test_helm_envd_contract.py"]
      },
      "commands": [
        {
          "id": "helm-envd-contract",
