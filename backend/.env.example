# Helm backend — example environment.
#
#   cp .env.example .env      # then fill in what you want to go live
#
# Every var is OPTIONAL. With an empty .env the backend runs fully in stub/mock mode
# (deterministic, no network, no keys). Each var below flips one capability from
# stub/mock to live.

# --- LLM (narration + dossier prose) ---------------------------------------
# Empty  -> /health reports llm:"stub"; narration/dossier are templated & deterministic.
# Set    -> /health reports llm:"openai"; a ReAct tool-calling loop writes real prose
#           grounded only in the returned data (no invented depths/fees).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Research agent web search ---------------------------------------------
# Empty  -> curated seed sources (real, openable links).
# Set    -> wire a live provider (Tavily/Bing/SerpAPI) in agents.py:search_web().
SEARCH_PROVIDER=

# --- Give-back: NoForeignLand track push -----------------------------------
# nfl.mode is "live" only when BOTH a key is present AND NFL_PUSH_ENABLED=true;
# otherwise pushes are mock-sent (status "sent-mock") so nothing leaves the machine.
NFL_BOAT_KEY=
NFL_PUSH_ENABLED=false

# --- Give-back: OpenStreetMap Notes ----------------------------------------
# false -> scaffold only (status "would-create"); true -> notes post for real.
OSM_NOTES_ENABLED=false

# --- Optional C++ engine origin (tides probe face) -------------------------
# Used by engine_client.get_tides_summary() for the AI spacetime probe.
# Empty -> http://127.0.0.1:8080 ; backend degrades honestly if helm-server is down.
HELM_ENGINE_URL=http://127.0.0.1:8080
