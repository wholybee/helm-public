# Helm region config — Fiji (Viti Levu), the primary cruising ground (demo nav center 177.4,-17.8).
# Box kept WEST of the antimeridian (180°) so the XYZ tile math (deg2num) doesn't wrap.
# Raise MAXZOOM for more coastal detail (cost ~4x tiles per level). Source: EOX Sentinel-2 cloudless
# (free, global, no licensing) — the same imagery the :8095 online-fill proxies.
REGION_NAME="fiji"
BBOX="176.9,-18.3,178.0,-17.2"
MINZOOM=7
MAXZOOM=12
SRC_SAT="https://tiles.maps.eox.at/wmts/1.0.0/s2cloudless-2020_3857/default/g/{z}/{y}/{x}.jpg"
