# Helm sample region config. Copy to pipeline/region.env for local overrides.
# This sample uses a public/demo Key West area, not a live vessel location.

REGION_NAME="key-west-demo"
# bounding box: West,South,East,North (lon/lat, WGS84). DEM depth contours use this box.
BBOX="-82.02,24.34,-81.52,24.72"
MINZOOM=9
MAXZOOM=13

# Tile sources (XYZ templates). Tokens {z}/{x}/{y} are substituted by name.
SRC_CHART="https://tileservice.charts.noaa.gov/tiles/50000_1/{z}/{x}/{y}.png"
# Sentinel-2 cloudless (EOX) — CC-BY-4.0. {z}/{y}/{x} order maps by name.
SRC_SAT="https://tiles.maps.eox.at/wmts/1.0.0/s2cloudless-2020_3857/default/g/{z}/{y}/{x}.jpg"

# Weather covers a wider box than the chart sample so the field fills the screen.
WIND_BBOX="-82.42,23.94,-81.12,25.12"
WIND_NX=20
WIND_NY=20
