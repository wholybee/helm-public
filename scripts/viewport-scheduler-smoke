#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MAIN="$ROOT/engine/vulkan/viewport_scheduler_smoke.cpp"
HDR="$ROOT/engine/vulkan/viewport_scheduler.h"
BIN="${HELM_VIEWPORT_SCHEDULER_SMOKE_BIN:-${TMPDIR:-/tmp}/helm-viewport-scheduler-smoke}"
CXX_BIN="${CXX:-c++}"

if [ ! -x "$BIN" ] || [ "$MAIN" -nt "$BIN" ] || [ "$HDR" -nt "$BIN" ]; then
  mkdir -p "$(dirname "$BIN")"
  "$CXX_BIN" -std=c++17 -O2 -Wall -Wextra -pedantic -I "$ROOT/engine/vulkan" "$MAIN" -o "$BIN"
fi

exec "$BIN" "$@"
