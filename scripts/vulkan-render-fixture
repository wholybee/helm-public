#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SRC="$ROOT/engine/vulkan/render_fixture.cpp"
BIN="${HELM_VULKAN_RENDER_FIXTURE_BIN:-${TMPDIR:-/tmp}/helm-vulkan-render-fixture}"
CXX_BIN="${CXX:-c++}"

if [ ! -x "$BIN" ] || [ "$SRC" -nt "$BIN" ]; then
  mkdir -p "$(dirname "$BIN")"
  "$CXX_BIN" -std=c++17 -O2 -Wall -Wextra -pedantic "$SRC" -o "$BIN"
fi

exec "$BIN" "$@"
