+target_compile_features(helm-basemap-cache PRIVATE cxx_std_17)
+target_include_directories(helm-basemap-cache PRIVATE ${PROJECT_SOURCE_DIR}/libs/IXWebSocket)
+target_link_libraries(helm-basemap-cache PRIVATE ixwebsocket)
