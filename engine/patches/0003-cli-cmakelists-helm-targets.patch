+add_executable(helm-symbol-runtime-gate-smoke helm_symbol_runtime_gate_smoke.cpp)
+set_property(TARGET helm-symbol-runtime-gate-smoke PROPERTY ENABLE_EXPORTS ON)
+target_link_libraries(helm-symbol-runtime-gate-smoke PRIVATE helm-symbol-package)
+
+add_library(helm-symbol-render-handoff STATIC helm_symbol_render_handoff.cpp)
+target_compile_features(helm-symbol-render-handoff PUBLIC cxx_std_17)
+target_link_libraries(helm-symbol-render-handoff PUBLIC helm-symbol-package)
+
+add_executable(helm-symbol-render-handoff-smoke helm_symbol_render_handoff_smoke.cpp)
+set_property(TARGET helm-symbol-render-handoff-smoke PROPERTY ENABLE_EXPORTS ON)
+target_link_libraries(helm-symbol-render-handoff-smoke PRIVATE helm-symbol-render-handoff)
