+# ---- Helm one-origin server: nav WS + S-52 tile HTTP + static UI on ONE port ----
+# api_shim.cpp is WIN32-only: on MSVC the plugin-API stubs in chart_stubs.cpp are
+# #ifndef _MSC_VER'd out, so helm-server links api_shim.cpp to supply them. On
+# macOS/Linux those stubs live in libhelm-chartrender.a, so also compiling
+# api_shim.cpp here would duplicate GetpSharedDataLocation() et al.
+add_executable(helm-server helm_server.cpp)
+if (WIN32)
+  target_sources(helm-server PRIVATE api_shim.cpp)
+endif ()
+set_property(TARGET helm-server PROPERTY ENABLE_EXPORTS ON)
+target_include_directories(helm-server PRIVATE ${PROJECT_SOURCE_DIR}/libs/IXWebSocket)
+target_link_libraries(helm-server PRIVATE ocpn::chart-render ocpn::tides ixwebsocket)
+if (WIN32)
+  target_link_libraries(helm-server PRIVATE psapi)
+endif ()
