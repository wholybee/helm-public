+# ---- Helm Engine skeleton: model/ nav core -> nav-state WebSocket (127.0.0.1:8081) ----
+add_executable(helm-engine helm_engine.cpp api_shim.cpp)
+set_property(TARGET helm-engine PROPERTY ENABLE_EXPORTS ON)
