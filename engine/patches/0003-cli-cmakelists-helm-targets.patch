+  ${PROJECT_SOURCE_DIR}/gui/src/tc_data_source.cpp
+  ${PROJECT_SOURCE_DIR}/gui/src/tc_data_factory.cpp
+  ${PROJECT_SOURCE_DIR}/gui/src/tcds_ascii_harmonic.cpp
+  ${PROJECT_SOURCE_DIR}/gui/src/tcds_binary_harmonic.cpp
+  ${PROJECT_SOURCE_DIR}/gui/src/station_data.cpp
+  ${PROJECT_SOURCE_DIR}/gui/src/idx_entry.cpp
+  ${PROJECT_SOURCE_DIR}/model/src/logger.cpp
+)
+add_library(helm-tides STATIC ${HELM_TIDES_GUI_SRC} helm_tides.cpp helm_tides_stubs.cpp)
+target_include_directories(helm-tides PUBLIC
+  ${PROJECT_SOURCE_DIR}/include
+  ${PROJECT_SOURCE_DIR}/model/include
+  ${PROJECT_SOURCE_DIR}/gui/include
+  ${PROJECT_SOURCE_DIR}/gui/include/gui
+  ${PROJECT_SOURCE_DIR}/resources)
+target_compile_definitions(helm-tides PUBLIC USE_MOCK_DEFS OCPN_HEADLESS)
+target_link_libraries(helm-tides PUBLIC ${wxWidgets_LIBRARIES})
+target_link_libraries(helm-tides PUBLIC ocpn::rapidjson)
+add_library(ocpn::tides ALIAS helm-tides)
+
+add_executable(helm-tides-smoke helm_tides_smoke.cpp)
+set_property(TARGET helm-tides-smoke PROPERTY ENABLE_EXPORTS ON)
+target_link_libraries(helm-tides-smoke PRIVATE ocpn::tides)
+
+add_executable(helm-tides-fetch helm_tides_fetch.cpp)
+set_property(TARGET helm-tides-fetch PROPERTY ENABLE_EXPORTS ON)
+target_include_directories(helm-tides-fetch PRIVATE ${PROJECT_SOURCE_DIR}/libs/IXWebSocket)
+target_link_libraries(helm-tides-fetch PRIVATE ocpn::tides ixwebsocket)
+
+# ---- Helm S-52 atlas builder: deterministic symbol/pattern/line-style assets ----
+add_library(helm-s52-atlas STATIC helm_s52_atlas.cpp)
+target_compile_features(helm-s52-atlas PUBLIC cxx_std_11)
+
+add_executable(helm-s52-atlas-builder helm_s52_atlas_builder.cpp)
+set_property(TARGET helm-s52-atlas-builder PROPERTY ENABLE_EXPORTS ON)
+target_link_libraries(helm-s52-atlas-builder PRIVATE helm-s52-atlas)
