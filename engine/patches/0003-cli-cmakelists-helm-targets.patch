+# ---- Helm Phase-1 spike: headless nav-core probe (mirrors opencpn-cmd) ----
+add_executable(helm-spike helm_spike.cpp api_shim.cpp)
+set_property(TARGET helm-spike PROPERTY ENABLE_EXPORTS ON)
+target_include_directories(helm-spike PRIVATE
+  ${PROJECT_SOURCE_DIR}/include ${PROJECT_SOURCE_DIR}/gui/include)
+target_compile_definitions(helm-spike PUBLIC USE_MOCK_DEFS)
+if (TARGET ocpn::wxcurl)
+  target_link_libraries(helm-spike PRIVATE ocpn::wxcurl)
+else ()
+  target_link_libraries(helm-spike PRIVATE ${SYS_WXCURL_LIBRARIES})
+endif ()
+target_link_libraries(helm-spike PRIVATE ${wxWidgets_LIBRARIES})
+if (TARGET ocpn::wxsvg)
+  target_link_libraries(helm-spike PRIVATE ocpn::wxsvg)
+endif ()
+target_link_libraries(helm-spike PRIVATE ocpn::serial ocpn::tinyxml ocpn::filesystem ocpn::gl-headers)
+if (HAVE_LIBUDEV)
+  target_link_libraries(helm-spike PRIVATE ocpn::libudev)
+endif ()
+target_link_libraries(helm-spike PRIVATE ocpn::model ocpn::model-src)
+# ---- Chart spike: headless S-57 ENC -> PNG (DC path, no GL) ----------------
+# Append to /tmp/opencpn/cli/CMakeLists.txt (after the helm-spike block).
+#
+# Compiles a hand-picked slice of gui/src (the s57chart render subgraph) plus
+# chart_spike.cpp + chart_stubs.cpp, links the in-tree static libs + model-src
+# + wxWidgets. ocpnUSE_GL is left UNDEFINED so the GL branches drop out.
+
+set(CHART_SPIKE_GUI_SRC
+  ${PROJECT_SOURCE_DIR}/gui/src/s57chart.cpp
+  ${PROJECT_SOURCE_DIR}/gui/src/s57obj.cpp
+  # NOTE: gui/src/s57_ocpn_utils.cpp is intentionally NOT compiled. It is a dead
+  # file (only its header is in the real GUI_SRC) and it RE-defines the three
+  # s57_*LightSectors() helpers that s57chart.cpp already defines -> duplicate
+  # symbols, plus it has a pi_rule_list type mismatch. The render path needs
+  # none of its symbols.
+  ${PROJECT_SOURCE_DIR}/gui/src/senc_manager.cpp
+  ${PROJECT_SOURCE_DIR}/gui/src/o_senc.cpp
+  ${PROJECT_SOURCE_DIR}/gui/src/ocpndc.cpp
+  ${PROJECT_SOURCE_DIR}/gui/src/viewport.cpp
+  ${PROJECT_SOURCE_DIR}/gui/src/ocpn_region.cpp
+  ${PROJECT_SOURCE_DIR}/gui/src/color_handler.cpp
+  # ocpnUSE_GL is defined for the whole tree (and is BAKED into the prebuilt
+  # libs' ABI -- e.g. s52plib has GL-only members), so we keep it ON and instead
+  # satisfy the GL globals these files reference. These three are small, self-
+  # contained TUs that DEFINE those globals + the DC pixel cache:
+  ${PROJECT_SOURCE_DIR}/gui/src/ocpn_pixel.cpp       # ocpnMemDC, ocpnBitmap (DC path)
+  ${PROJECT_SOURCE_DIR}/gui/src/shaders.cpp          # shader-program globals, preamble
+  ${PROJECT_SOURCE_DIR}/gui/src/ocpn_gl_options.cpp  # g_GLOptions
+)
+
+# ---- ocpn::chart-render — first-class static library for the headless S-52
+#      renderer (Step 6). Was a per-executable gui/src slice + stubs; now a
+#      reusable library that chart-spike AND helm-tiles link. OCPN_HEADLESS
+#      severs the plugin dynamic_cast, so NO faked RTTI (chart_typeinfo.cpp) is
+#      needed. PUBLIC usage requirements (includes/defs/libs) flow to consumers,
+#      and GetpSharedDataLocation() lives in chart_stubs.cpp so the library has
+#      no back-reference to its host executable.
+add_library(helm-chartrender STATIC ${CHART_SPIKE_GUI_SRC} chart_stubs.cpp)
+target_include_directories(helm-chartrender PUBLIC
+  ${PROJECT_SOURCE_DIR}/include
+  ${PROJECT_SOURCE_DIR}/gui/include
+  ${PROJECT_SOURCE_DIR}/gui/include/gui
+  ${PROJECT_SOURCE_DIR}/gui/src/s57/include
+  ${PROJECT_SOURCE_DIR}/libs/s52plib/src
+  ${PROJECT_SOURCE_DIR}/libs/s57-charts/include
+  ${PROJECT_SOURCE_DIR}/libs/geoprim/include
+  ${PROJECT_SOURCE_DIR}/libs/ssl_sha1/include)
+target_compile_definitions(helm-chartrender PUBLIC USE_MOCK_DEFS OCPN_HEADLESS)
+target_link_libraries(helm-chartrender PUBLIC
+  ocpn::s52plib ocpn::s57-charts ocpn::geoprim ocpn::iso8211 ocpn::gl-headers
+  ocpn::model-src ocpn::model ssl::sha1
+  ocpn::serial ocpn::tinyxml ocpn::filesystem
+  ${wxWidgets_LIBRARIES})
+if (TARGET ocpn::wxcurl)
+  target_link_libraries(helm-chartrender PUBLIC ocpn::wxcurl)
+endif ()
+if (TARGET ocpn::wxsvg)
+  target_link_libraries(helm-chartrender PUBLIC ocpn::wxsvg)
+endif ()
+if (HAVE_LIBUDEV)
+  target_link_libraries(helm-chartrender PUBLIC ocpn::libudev)
+endif ()
+add_library(ocpn::chart-render ALIAS helm-chartrender)
+
+# chart-spike: the proof harness, now just a main linking the library.
+add_executable(chart-spike chart_spike.cpp)
+set_property(TARGET chart-spike PROPERTY ENABLE_EXPORTS ON)
+target_link_libraries(chart-spike PRIVATE ocpn::chart-render)
+
