diff --git a/gui/src/s57chart.cpp b/gui/src/s57chart.cpp
index eb5a18e..734c779 100644
--- a/gui/src/s57chart.cpp
+++ b/gui/src/s57chart.cpp
@@ -4122,12 +4122,35 @@ int s57chart::BuildRAZFromSENCFile(const wxString &FullPath) {
   ref_lat = (ext.NLAT + ext.SLAT) / 2.;
   ref_lon = (ext.ELON + ext.WLON) / 2.;
 
+  // Propagate the SENC-encoded native (compilation) scale (DSPM:CSCL) into this
+  // chart so GetNativeScale() is correct on the headless / full-Init path, which
+  // skips the GUI-only CreateHeaderDataFromoSENC() pass. Without this the scale
+  // stays at the constructor default of 1, and SUPER_SCAMIN then culls the
+  // DEPCNT/DEPARE/SOUNDG features that draw the safety contour and the dangerous
+  // soundings. Surface a bad scale loudly; never render silently at scale 1.
+  int senc_scale = sencfile.getSENCReadScale();
+  if (senc_scale > 1) {
+    m_Chart_Scale = senc_scale;
+  } else {
+    wxLogMessage(_T("s57chart WARNING: SENC native scale missing/invalid (%d) ")
+                 _T("for %s; SCAMIN / safety-contour filtering would be ")
+                 _T("unreliable."), senc_scale, FullPath);
+  }
+
   //  Process the Edge feature arrays.
 
   //    Create a hash map of VE_Element pointers as a chart class member
   int n_ve_elements = VEs.size();
 
+#ifdef OCPN_HEADLESS
+  // Headless engine has no GUI top-frame. `scale` is only passed to
+  // SendVectorChartObjectInfo() below — a plugin notification that is a no-op
+  // with no plugins loaded — so use this chart's true native scale directly
+  // rather than routing the render path through a stub frame.
+  double scale = GetNativeScale();
+#else
   double scale = top_frame::Get()->GetBestVPScale(this);
+#endif
   int nativescale = GetNativeScale();
 
   for (int i = 0; i < n_ve_elements; i++) {
@@ -6888,7 +6911,15 @@ bool s57_GetVisibleLightSectors(ChartCanvas *cc, double lat, double lon,
   if (target_chart) {
     if ((target_chart->GetChartType() == CHART_TYPE_PLUGIN) &&
         (target_chart->GetChartFamily() == CHART_FAMILY_VECTOR))
+#ifdef OCPN_HEADLESS
+      // Headless engine links no plugin charts, so this plugin-chart branch is
+      // unreachable. Compiling the dynamic_cast would force a typeinfo for
+      // ChartPlugInWrapper at link, dragging the plugin/BSB code (or a faked RTTI
+      // symbol). Sever it structurally instead.
+      target_plugin_chart = NULL;
+#else
       target_plugin_chart = dynamic_cast<ChartPlugInWrapper *>(target_chart);
+#endif
     else
       Chs57 = dynamic_cast<s57chart *>(target_chart);
   }
@@ -6943,7 +6974,15 @@ bool s57_CheckExtendedLightSectors(ChartCanvas *cc, int mx, int my,
   if (target_chart) {
     if ((target_chart->GetChartType() == CHART_TYPE_PLUGIN) &&
         (target_chart->GetChartFamily() == CHART_FAMILY_VECTOR))
+#ifdef OCPN_HEADLESS
+      // Headless engine links no plugin charts, so this plugin-chart branch is
+      // unreachable. Compiling the dynamic_cast would force a typeinfo for
+      // ChartPlugInWrapper at link, dragging the plugin/BSB code (or a faked RTTI
+      // symbol). Sever it structurally instead.
+      target_plugin_chart = NULL;
+#else
       target_plugin_chart = dynamic_cast<ChartPlugInWrapper *>(target_chart);
+#endif
     else
       Chs57 = dynamic_cast<s57chart *>(target_chart);
   }
